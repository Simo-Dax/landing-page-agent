# === Template chiavi del framework ===
# Copia questo file in .env e inserisci i valori reali. NON committare .env.

# --- Firecrawl (ricerca/scrape/design-clone) ---
FIRECRAWL_API_KEY=

# --- Supabase (MCP + app) ---
# Access token per il Supabase MCP (dashboard → Account → Access Tokens)
SUPABASE_ACCESS_TOKEN=
# Per l'app (Fase 9)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# --- Clerk (auth, Fase 8) ---
# MCP Clerk = via connettore claude.ai (snippet). Provisioning a mano dalla dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Vercel (deploy, Fase 11) ---
# Il Vercel MCP (.mcp.json) usa OAuth al primo collegamento. Token opzionale per CLI:
VERCEL_TOKEN=

# --- Cloudflare (hardening opzionale, Fase 11) ---
# Solo col dominio reale. WAF/DDoS/bot/rate-limit/Turnstile. Config da dashboard; token per automazioni:
CLOUDFLARE_API_TOKEN=
# Chiavi Turnstile per i form (sito + secret):
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Specifico per progetto (NON parte del framework generale) ---
# Esempio 25 Lezioni: integrazione email Sendfox
# SENDFOX_API_TOKEN=
